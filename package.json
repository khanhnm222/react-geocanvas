{
  "name": "react-geovisualizer",
  "version": "1.0.0",
  "description": "Lightweight React library for rendering GeoJSON, KML and Shapefile data directly onto HTML5 Canvas — fast, map-free geographic visualization with zero runtime dependencies.",
  "license": "MIT",
  "author": "Khanh Nguyen",
  "keywords": [
    "react",
    "geojson",
    "kml",
    "shapefile",
    "canvas",
    "map",
    "gis",
    "geographic",
    "visualization",
    "geo",
    "renderer",
    "mercator"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khanhnm222/react-geovisualizer.git"
  },
  "bugs": {
    "url": "https://github.com/khanhnm222/react-geovisualizer/issues"
  },
  "homepage": "https://github.com/khanhnm222/react-geovisualizer#readme",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "echo \"No tests yet\" && exit 0",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.16",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "eslint": "^9.36.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  }
}
